# AI_PROVIDER=mock 完全本地运行，走 backend/app/services/mock_llm.py，不调用外部服务。
# 切换真实模型：AI_PROVIDER=openai_compatible，并配置任意 Chat Completions 兼容服务
#（OpenAI / DeepSeek / 通义 / 智谱 / vLLM / Ollama 网关等）。
#
# 可靠性说明：真实接口调用失败（网络/鉴权/JSON 解析）会自动回退 mock，
# 响应中带 fallback=true 与 fallback_reason，演示现场不会中断。
AI_PROVIDER=mock
AI_API_BASE_URL=https://api.example.com/v1
AI_API_KEY=replace-with-your-api-key
AI_MODEL=replace-with-your-model-name
# 可选：真实接口超时秒数（默认 45）
AI_TIMEOUT_SECONDS=45
